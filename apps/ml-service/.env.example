# ========================================
# LLM Forge ML Service — Environment Variables
# ========================================
# Copy to .env and fill in values

# App
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Database (matches docker-compose)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/llmforge

# Redis (matches docker-compose)
REDIS_URL=redis://redis:6379/0

# S3 / MinIO (matches docker-compose)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DATASETS=llmforge-datasets
S3_BUCKET_CHECKPOINTS=llmforge-checkpoints
S3_BUCKET_MODELS=llmforge-models
S3_REGION=us-east-1

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Inter-service auth (shared with Next.js)
INTERNAL_API_SECRET=dev-secret-change-me-in-production

# HuggingFace
HF_TOKEN=
HF_CACHE_DIR=/tmp/hf_cache

# Training
MAX_CONCURRENT_JOBS=10
DEFAULT_CHECKPOINT_INTERVAL=500
MAX_TRAINING_HOURS=24
